<% layout("/layouts/boiler") %>

<div class="row" style="display: flex; justify-content: center;">
    <div class="col-7" style="padding: 0rem; margin: 1rem !important; border: 2px solid rgba(0, 0, 0, .5) !important; border-radius: 1rem !important;">
        <h1 class="mb-4" style="margin: .5rem 1rem;"><i><%= item.title %></i></h1>
        <form method="POST" action="/allList/<%= item._id %>/edit?_method=PUT" novalidate class="needs-validation">
            
            <div class="mb-3 col-5 title" style="margin: 0rem 1rem !important;">
                <label for="listing_title" class="form-label">Title</label>
                <input type="text" class="form-control" id="listing_title" name="listing[title]" value="<%= item.title %>" required minlength="3" maxlength="100">
                <div class="invalid-feedback">Title must be 3-100 characters</div>
            </div>

            <div class="mb-3 col-20 desc" style="margin: 0rem 1rem !important;">
                <label for="listing_description" class="form-label">Description</label>
                <textarea class="form-control" id="listing_description" name="listing[description]" rows="6" required minlength="10"><%= item.description %></textarea>
                <div class="invalid-feedback">Description must be at least 10 characters</div>
            </div>

            <div class="mb-3 image" style="margin: 0rem 1rem !important;">
                <label for="listing_image_url" class="form-label">Image URL</label>
                <input type="url" class="form-control" id="listing_image_url" name="listing[image][url]" value="<%= item.image.url %>">
            </div>

            <div class="row mb-4">
                <div class="col-md-2 mb-3 price" style="margin: 0rem 1rem !important;">
                    <label for="listing_price" class="form-label">Price (₹)</label>
                    <input type="number" class="form-control" id="listing_price" name="listing[price]" value="<%= item.price %>" required min="0" step="0.01">
                    <div class="invalid-feedback">Enter valid price (≥ 0)</div>
                </div>
        
                <div class="col-md-3 mb-3 location" style="margin: 0rem 1rem !important;">
                    <label for="listing_location" class="form-label">Location</label>
                    <input type="text" class="form-control" id="listing_location" name="listing[location]" value="<%= item.location %>" required>
                    <div class="invalid-feedback">Enter location</div>
                </div>

                <div class="col-md-3 mb-3 country" style="margin: 0rem 1rem !important;">
                    <label for="listing_country" class="form-label">Country</label>
                    <input type="text" class="form-control" id="listing_country" name="listing[country]" value="<%= item.country %>" required>
                    <div class="invalid-feedback">Enter country</div>
                </div>
            </div>
            
            <div class="d-flex gap-2" style="margin: 1rem 1rem !important;">
                <button type="submit" class="btn btn-success btn-md">Update</button>
                <a href="/allList/<%= item._id %>" class="btn btn-danger btn-md">Cancel</a>
            </div>
        </form>
    </div>
</div>
